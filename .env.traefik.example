# SkillHub Traefik deployment configuration
# Copy this to .env.traefik and replace every value marked TODO.
#
# Prerequisites:
# 1. Traefik must be running and connected to the 'shared' network
# 2. ForwardAuth middlewares must be defined in Traefik config:
#    - cas-auth: CAS authentication (outputs X-User-Id)
#    - user-info-optional: User info enrichment (outputs X-User-Name, etc.)
# 3. Build web image with VITE_BASE_PATH matching TRAEFIK_PATH_PREFIX:
#    docker build --build-arg VITE_BASE_PATH=/skillhub -t skillhub-web:traefik ./web
#
# Usage:
#    docker compose --env-file .env.traefik -f compose.traefik.yml up -d

# All images must be built locally.
# Examples:
#   docker build -t skillhub-server:traefik ./server
#   docker build --build-arg VITE_BASE_PATH=/skillhub -t skillhub-web:traefik ./web
#   docker build -t skillhub-scanner:traefik ./scanner
SKILLHUB_SERVER_IMAGE=skillhub-server:traefik
SKILLHUB_WEB_IMAGE=skillhub-web:traefik
SKILLHUB_SCANNER_IMAGE=skillhub-scanner:traefik
POSTGRES_IMAGE=postgres:16-alpine
REDIS_IMAGE=redis:7-alpine

# Traefik routing configuration
# PathPrefix for routing requests to SkillHub (must match VITE_BASE_PATH used during build)
TRAEFIK_PATH_PREFIX=/skillhub

# Admin entry: separate host for password-login admin UI
# Access: skillhub-admin.your-domain.com/skillhub
# Protected by admin-ip-whitelist (defined in gateway-cas Traefik config)
TRAEFIK_ADMIN_HOST=skillhub-admin.localhost

# Public HTTPS entrypoint for CAS users, no trailing slash.
# Must include the path prefix if using sub-path deployment.
SKILLHUB_PUBLIC_BASE_URL=https://example.com/skillhub

# Public HTTPS entrypoint for admin (password login), no trailing slash.
# Shown as base URL in admin portal; should include /skillhub path.
SKILLHUB_PUBLIC_ADMIN_BASE_URL=https://skillhub-admin.example.com/skillhub

# Must match TRAEFIK_PATH_PREFIX so API calls route through Traefik.
# After StripPrefix, nginx proxies /api/ to the backend server.
SKILLHUB_WEB_API_BASE_URL=/skillhub
SKILLHUB_API_UPSTREAM=http://server:8080

# Database configuration (no host port exposure in Traefik mode)
POSTGRES_DB=skillhub
POSTGRES_USER=skillhub
POSTGRES_PASSWORD=TODO_change_to_a_strong_database_password

# Redis configuration (no host port exposure in Traefik mode)
# API port is not exposed - accessed only through Traefik

# Must stay true when behind Traefik with HTTPS.
SESSION_COOKIE_SECURE=true

# Storage provider: local or s3. Local uses the skillhub_storage volume.
SKILLHUB_STORAGE_PROVIDER=local

# S3 configuration (optional - only needed when SKILLHUB_STORAGE_PROVIDER=s3)
SKILLHUB_STORAGE_S3_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com
SKILLHUB_STORAGE_S3_PUBLIC_ENDPOINT=
SKILLHUB_STORAGE_S3_BUCKET=skillhub-prod
SKILLHUB_STORAGE_S3_ACCESS_KEY=TODO_fill_real_access_key
SKILLHUB_STORAGE_S3_SECRET_KEY=TODO_fill_real_secret_key
SKILLHUB_STORAGE_S3_REGION=cn-shanghai
SKILLHUB_STORAGE_S3_FORCE_PATH_STYLE=false
SKILLHUB_STORAGE_S3_AUTO_CREATE_BUCKET=false
SKILLHUB_STORAGE_S3_PRESIGN_EXPIRY=PT10M

# Bootstrap admin account (used for admin password login via web-admin portal)
# Keep enabled: creates a SUPER_ADMIN with local credentials on first start.
# After initial setup you can manage additional admin accounts via the admin UI.
BOOTSTRAP_ADMIN_ENABLED=true
BOOTSTRAP_ADMIN_USER_ID=docker-admin
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=TODO_change_to_a_strong_admin_password
BOOTSTRAP_ADMIN_DISPLAY_NAME=Platform Admin
BOOTSTRAP_ADMIN_EMAIL=admin@example.com

# Direct auth (password login endpoint on server) — required for web-admin portal.
# CAS users authenticate via trusted header, so this only affects admin login.
SKILLHUB_AUTH_DIRECT_ENABLED=true

# Usually keep empty and let the backend derive it from SKILLHUB_PUBLIC_BASE_URL.
DEVICE_AUTH_VERIFICATION_URI=

# Trusted Header Authentication (ForwardAuth)
# These are enabled by default in Traefik deployment.
# Using gateway-cas middleware chain: cas-auth,user-info-*
SKILLHUB_AUTH_TRUSTED_HEADER_ENABLED=true
# gateway-cas cas-auth middleware outputs X-User-Id
SKILLHUB_AUTH_TRUSTED_HEADER_USER_ID_HEADER=X-User-Id
# gateway-cas does not provide email by default, leave empty
SKILLHUB_AUTH_TRUSTED_HEADER_EMAIL_HEADER=
# gateway-cas user-info-proxy outputs X-User-Name for display name
SKILLHUB_AUTH_TRUSTED_HEADER_DISPLAY_NAME_HEADER=X-User-Name
SKILLHUB_AUTH_TRUSTED_HEADER_AUTO_PROVISION=true

# Frontend trusted header configuration
SKILLHUB_WEB_AUTH_TRUSTED_HEADER_ENABLED=true
# CAS logout URL (gateway-cas cas-proxy handles logout at /cas/logout)
# Append ?redirect=<url> to specify the post-logout redirect target.
# The redirect URL must share the same origin with gateway-cas SERVICE_BASE_URL.
# Example: http://localhost/cas/logout?redirect=http://localhost/skillhub
SKILLHUB_WEB_AUTH_TRUSTED_HEADER_LOGOUT_URL=http://localhost/cas/logout?redirect=http://localhost/skillhub

# Security scanner is enabled by default.
SKILLHUB_SECURITY_SCANNER_ENABLED=true

# Scanner LLM configuration (optional, for AI-powered scanning features)
SKILL_SCANNER_LLM_API_KEY=
SKILL_SCANNER_LLM_BASE_URL=
SKILL_SCANNER_LLM_MODEL=
